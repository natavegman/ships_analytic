# Notion sync после обогащения конкурента (prepare_notion_import + опционально notion_reimport)
# NOTION_SYNC=1
# NOTION_API_TOKEN=secret_...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# API_PORT=8000

# Токен Global Fishing Watch (для карты наших судов и скрипта build_gfw_vessel_cache.py)
# Получить: https://globalfishingwatch.org/our-apis/tokens
# GFW_API_TOKEN=your_token_here

# Порт веб-сервера карты (по умолчанию 5000)
# PORT=5000

# DataNewton API (обогащение компаний — директора, учредители, связи, финансы)
# Получить: https://datanewton.ru → Регистрация → API ключ
# 200 запросов бесплатно, 200 запросов/мин
# DATANEWTON_API_KEY=your_key_here

# DaData API (очистка названий компаний и директоров по ИНН)
# Получить: https://dadata.ru/profile/#info
# DADATA_API_KEY=your_api_key_here
# DADATA_SECRET_KEY=your_secret_key_here

# PostgreSQL (Sprint 1/2 DWH) — см. docker-compose.yml в корне проекта
# После: docker compose up -d
DATABASE_URL=postgresql+psycopg2://quotas:quotas_local_dev@localhost:5432/quotas_analytic
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=quotas_analytic
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# Notion API (для автоматического создания баз и импорта данных)
# Создать интеграцию: https://www.notion.so/my-integrations
# NOTION_API_TOKEN=secret_xxx
# NOTION_PARENT_PAGE_ID=xxx  # ID страницы-хаба (32 символа из URL)
